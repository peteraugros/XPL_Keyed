# ============================================================================
# XPL Keyed ‚Äî env vars
# ============================================================================
# Copy to `.env.local` and fill in. Never commit `.env.local`.

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server-only, NEVER expose to client

# ---------- Stripe ----------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/...  # customer-portal login URL from the Stripe dashboard

# ---------- Calendly ----------
CALENDLY_PAT=eyJ...                       # personal access token for API calls
CALENDLY_WEBHOOK_SECRET=...               # signing secret for webhook verification

# ---------- Resend ----------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=tim@xplkeyed.com        # must match verified Resend domain

# ---------- Anthropic (lesson-authoring AI assist) ----------
ANTHROPIC_API_KEY=sk-ant-...               # https://console.anthropic.com/

# ---------- Discord ----------
DISCORD_BOT_TOKEN=...                     # XPL Keyed Bot, from Developer Portal
DISCORD_GUILD_ID=...                      # Tim's coaching server id
DISCORD_TIM_USER_ID=...                   # Tim's Discord user id (for DM target)

# ---------- Web push (VAPID keys, generate via `npx web-push generate-vapid-keys`) ----------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:tim@xplkeyed.com

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
